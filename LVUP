const MAX_LEVEL = 255;
const DAILY_XP_CAP = 300;

const xpForLevel = (level) => Math.floor(95 * Math.pow(level, 1.26));
const totalXpForLevel = (level) => {
  let total = 0;
  for (let i = 1; i < level; i++) total += xpForLevel(i);
  return total;
};

const levelFromXp = (xp) => {
  let level = 1;
  while (level < MAX_LEVEL && xp >= totalXpForLevel(level + 1)) level++;
  return level;
};

