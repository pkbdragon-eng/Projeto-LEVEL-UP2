function normalizeText(text) {
  return (text || "")
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .trim();
}

function detectStatBoosts(text, map, baseBoost = 2) {
  const normalized = normalizeText(text);
  const boosts = { str: 0, agi: 0, end: 0, int: 0, disc: 0, tec: 0 };

  Object.entries(map).forEach(([stat, terms]) => {
    terms.forEach((term) => {
      if (normalized.includes(normalizeText(term))) {
        boosts[stat] += baseBoost;
      }
    });
  });

  return boosts;
}

function getStageIcon(gender, level) {
  const list = stageIcons[gender] || stageIcons.male;
  const index = Math.min(list.length - 1, Math.floor(level / 40));
  return list[index];
}

function Radar({ stats }) {
  const labels = ["STR", "AGI", "END", "INT", "DISC", "TEC"];
  const values = [stats.str, stats.agi, stats.end, stats.int, stats.disc, stats.tec];
  const size = 320;
  const center = size / 2;
  const radius = 110;
  const grid = [20, 40, 60, 80, 100];

  const makePoints = () =>
    values
      .map((v, i) => {
        const angle = -Math.PI / 2 + (i * Math.PI * 2) / labels.length;
        const r = radius * (v / 100);
        const x = center + Math.cos(angle) * r;
        const y = center + Math.sin(angle) * r;
        return `${x},${y}`;
      })
      .join(" ");

  return (
    <svg viewBox={`0 0 ${size} ${size}`} className="w-full max-w-[340px] mx-auto">
      <defs>
        <linearGradient id="radarFill" x1="0" x2="1" y1="0" y2="1">
          <stop offset="0%" stopColor="#4338ca" stopOpacity="0.32" />
          <stop offset="100%" stopColor="#a855f7" stopOpacity="0.22" />
        </linearGradient>
      </defs>

      {grid.map((g) => (
        <polygon
          key={g}
          points={labels
            .map((_, i) => {
              const angle = -Math.PI / 2 + (i * Math.PI * 2) / labels.length;
              const r = radius * (g / 100);
              const x = center + Math.cos(angle) * r;
              const y = center + Math.sin(angle) * r;
              return `${x},${y}`;
            })
            .join(" ")}
          fill="none"
          stroke="#e5e7eb"
        />
      ))}

      {labels.map((label, i) => {
        const angle = -Math.PI / 2 + (i * Math.PI * 2) / labels.length;
        const x2 = center + Math.cos(angle) * radius;
        const y2 = center + Math.sin(angle) * radius;
        const lx = center + Math.cos(angle) * (radius + 22);
        const ly = center + Math.sin(angle) * (radius + 22);
        return (
          <g key={label}>
            <line x1={center} y1={center} x2={x2} y2={y2} stroke="#ececf1" />
            <text x={lx} y={ly} textAnchor="middle" fontSize="12" fill="#71717a" fontWeight="600">
              {label}
            </text>
          </g>
        );
      })}

      <polygon points={makePoints()} fill="url(#radarFill)" stroke="#4f46e5" strokeWidth="2.5" />
    </svg>
  );
}

